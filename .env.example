PORT=5000
NODE_ENV=development

# CORS — browser origin for the Next.js app (comma-separated for multiple URLs)
CLIENT_URL=http://localhost:3000

MONGO_URI=mongodb://127.0.0.1:27017/docvera
# Optional: MongoDB driver pool (default 10)
# MONGO_MAX_POOL_SIZE=10

JWT_SECRET=change-me-in-production

# API rate limit (defaults: 100 requests per 15 minutes per IP)
# API_RATE_WINDOW_MS=900000
# API_RATE_MAX=100

# Emergency feature kill-switches (true/false). Default: all enabled.
# FEATURE_PAYMENT=true
# FEATURE_CHAT=true
# FEATURE_UPLOAD=true
# FEATURE_AI=true

# Web Push (VAPID) — run: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:support@example.com

# Redis: Socket.IO adapter + HTTP response cache + BullMQ (required in production).
# Example: redis://127.0.0.1:6379
# Local dev without Redis: set REDIS_DISABLED=1 to avoid connection attempts / log spam.
# REDIS_URL=redis://127.0.0.1:6379
# REDIS_DISABLED=1

# Dev only: run order jobs in-process without Redis (ORDER_JOBS_DEV_MEMORY=1). Not for production.
# ORDER_JOBS_DEV_MEMORY=1

# Run BullMQ order worker inside the API process (dev/single-node). Production: use worker:orders instead.
# ORDER_JOBS_RUN_WORKER_IN_API=1
